---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
---

<Layout>
  <main id="main-content" data-layout="index">
    <header>
      <h1>Nazar Gladish</h1>
      <button id="theme-btn" class="theme-toggle" aria-label="Toggle theme">
        <span class="toggle-track">
          <span class="toggle-thumb"></span>
        </span>
      </button>
    </header>

    <section class="bio">
      <p>
        I'm 19, founder of Kestrel. Taught myself to code, moved to Poland at
        17, and was working as a software engineer the week I turned 18. A year
        in, I earned a senior&#8209;engineer trial at <a
          href="https://github.com/antiwork"
          target="_blank"
          rel="noopener noreferrer">Gumroad (Antiwork)</a
        > and shipped to a UK platform with 7M monthly users. Now I'm full-time
        on my own thing.
      </p>
    </section>

    {
      sortedPosts.length > 0 && (
        <section class="section">
          <h2>Posts</h2>
          <ul class="link-list">
            {sortedPosts.map(post => (
              <li>
                <a href={getPath(post.id, post.filePath)}>{post.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="section">
      <h2>Links</h2>
      <ul class="link-list">
        <li>
          <a
            href="https://x.com/nazargladish"
            target="_blank"
            rel="noopener noreferrer">X (Twitter)</a
          >
        </li>
        <li>
          <a href="mailto:hi@nazargladish.com">Email</a>
        </li>
      </ul>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>

<style>
  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 24px 4rem;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 29px;
    font-weight: 600;
    margin: 0;
  }

  .bio {
    margin-bottom: 2.5rem;
  }

  .bio p {
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .bio a {
    text-decoration: underline;
  }

  .section {
    margin-bottom: 2rem;
  }

  .section h2 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
  }

  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .link-list li {
    margin-bottom: 0.25rem;
  }

  .link-list a {
    font-size: 1.05rem;
  }
</style>
