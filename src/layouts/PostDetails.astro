---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import tz from "dayjs/plugin/timezone";

dayjs.extend(utc);
dayjs.extend(tz);

export interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
} = post.data;

const { Content, headings } = await render(post);

const datetime = dayjs(pubDatetime).tz(timezone || SITE.timezone);
const formattedDate = datetime.format("MMMM YYYY");

let ogImageUrl: string | undefined;
if (typeof initOgImage === "string") ogImageUrl = initOgImage;
else if (initOgImage?.src) ogImageUrl = initOgImage.src;
if (!ogImageUrl && SITE.dynamicOgImage)
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

const tocHeadings = headings.filter(h => h.depth <= 3);
---

<Layout {...layoutProps}>
  <div class="post-layout">
    {
      tocHeadings.length > 0 && (
        <aside class="toc-sidebar">
          <h2 class="toc-title">Contents</h2>
          <ul class="toc-list">
            {tocHeadings.map((heading, i) => (
              <li class={heading.depth === 3 ? "toc-sub" : ""}>
                <a href={`#${heading.slug}`}>
                  {heading.depth === 2 ? `${i + 1}. ${heading.text}` : heading.text}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }

    <main id="main-content" data-pagefind-body>
      <header class="post-header">
        <a href="/" class="site-name">Nazar Gladish</a>
        <button id="theme-btn" class="theme-toggle" aria-label="Toggle theme">
          <span class="toggle-track">
            <span class="toggle-thumb"></span>
          </span>
        </button>
      </header>
      <h1 transition:name={slugifyStr(title)}>
        {title}
      </h1>
      {description && <p class="subtitle"><em>{description}</em></p>}
      <p class="post-date">{formattedDate}</p>

      <article class="prose">
        <Content />
      </article>
    </main>
  </div>
</Layout>

<script is:inline data-astro-rerun>
  function createProgressBar() {
    const progressContainer = document.createElement("div");
    progressContainer.className = "progress-container";
    progressContainer.style.cssText =
      "position:fixed;top:0;left:0;width:100%;height:3px;z-index:100;";
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar";
    progressBar.id = "myBar";
    progressBar.style.cssText =
      "height:100%;width:0%;background:var(--text-muted);transition:width 0.1s;";
    progressContainer.appendChild(progressBar);
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const myBar = document.getElementById("myBar");
      if (myBar) myBar.style.width = scrolled + "%";
    });
  }
  updateScrollProgress();

  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      if (heading.closest(".toc-sidebar")) continue;
      if (!heading.id) continue;
      const link = document.createElement("a");
      link.href = "#" + heading.id;
      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));
    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";
      const copyButton = document.createElement("button");
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);
      copyButton.addEventListener("click", async () => {
        const code = codeBlock.querySelector("code");
        const text = code?.innerText;
        await navigator.clipboard.writeText(text ?? "");
        copyButton.innerText = "Copied";
        setTimeout(() => {
          copyButton.innerText = copyButtonLabel;
        }, 700);
      });
    }
  }
  attachCopyButtons();

  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>

<style>
  .post-header {
    display: flex;
    align-items: center;
    padding: 0 0 2rem 0;
  }

  .site-name {
    font-weight: 600;
    font-size: 29px;
    flex: 1;
    text-decoration: none;
  }

  .site-name:hover {
    text-decoration: none;
  }

  .post-layout {
    display: flex;
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
    gap: 3rem;
  }

  .toc-sidebar {
    width: 200px;
    flex-shrink: 0;
    position: sticky;
    top: 80px;
    align-self: flex-start;
  }

  .toc-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-list li {
    margin-bottom: 0.5rem;
  }

  .toc-list .toc-sub {
    padding-left: 1rem;
  }

  .toc-list a {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.4;
    display: block;
  }

  .toc-list a:hover {
    color: var(--text-color);
    text-decoration: none;
  }

  main {
    flex: 1;
    max-width: 680px;
    padding: 0;
  }

  h1 {
    font-size: 62px;
    line-height: 1.1;
    margin: 0 0 0.5rem 0;
  }

  .subtitle {
    font-size: 1.2rem;
    margin-bottom: 1rem;
    color: var(--text-muted);
  }

  .post-date {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }

  .prose {
    font-size: 20px;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .post-layout {
      flex-direction: column;
      padding: 1rem 1rem 3rem;
      gap: 1.5rem;
    }

    .toc-sidebar {
      position: static;
      width: 100%;
    }

    h1 {
      font-size: 2.5rem;
    }
  }
</style>
